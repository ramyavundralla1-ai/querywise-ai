# ── QueryWise AI Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.

# Fireworks AI API Key  (get one at https://fireworks.ai)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database
DUCKDB_PATH=data/querywise.duckdb

# Logging
LOG_LEVEL=INFO